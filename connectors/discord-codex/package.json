{
  "name": "@wakefield/discord-codex-connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord inbound bridge and Discord MCP tools for live Codex app threads.",
  "bin": {
    "discord-codex-bot": "src/discord-bot.mjs",
    "discord-codex-mcp": "src/mcp-server.mjs",
    "discord-codex-probe-follower": "src/codex-follower-probe.mjs",
    "discord-codex-send": "src/codex-send.mjs"
  },
  "scripts": {
    "bot": "node src/discord-bot.mjs",
    "mcp": "node src/mcp-server.mjs",
    "probe:follower": "node src/codex-follower-probe.mjs",
    "send": "node src/codex-send.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "node --check src/*.mjs && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "discord.js": "^14.19.3",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20"
  }
}
